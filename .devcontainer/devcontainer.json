{
	"name": "kernelo_devcontainer",

	"runArgs": ["--name", "kernelo_dev_container"], // defines container name
	// defining image name is not yet available in dev containers (https://github.com/microsoft/vscode-remote-release/issues/2485). Stay aware of any new features.

	// "initializeCommand": "docker build -f .devcontainer/kernelo_devcontainer.Dockerfile -t kernelo_dev_image .",
	
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	// "image": "kernelo_python_runner",
	"build": {
		// Path is relative to the devcontainer.json file.
		"dockerfile": "kernelo_devcontainer.Dockerfile"
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"ms-vscode.cpptools",
				"ms-vscode.cpptools-extension-pack",
				"ms-vscode.cpptools-themes",
				"twxs.cmake",
				"ms-vscode.cmake-tools",
				"mhutchie.git-graph",
				"VisualStudioExptTeam.vscodeintellicode",
				"VisualStudioExptTeam.intellicode-api-usage-examples",
				"ms-python.vscode-pylance",
				"ms-python.python"
			]
		}
	}

	// "forwardPorts": [3000],

	// "portsAttributes": {
	// 	"3000": {
	// 		"label": "Hello Remote World",
	// 		"onAutoForward": "notify"
	// 	}
	// }


	// "remoteUser": "root"
}
